# ============================================
# Shop Now - Environment Variables
# ============================================
# This file documents all environment variables used in the monorepo.
# Copy this to .env and update with your values.
#
# This is a centralized .env file for the entire turborepo.
# All apps and packages in this monorepo load their environment
# variables from this single source of truth at the root.
#
# Apps/packages should NOT have their own .env files.
# For local development overrides, use .env.local (not committed).
# ============================================

# ============================================
# API Server Configuration
# ============================================
# The port on which the API server listens
PORT=4000

# Node environment (development, production, test, etc.)
NODE_ENV=development

# ============================================
# Database URLs - Direct Connection
# ============================================
# Used for migrations, seeds, and admin operations
# Connect directly to the primary PostgreSQL database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# ============================================
# Database URLs - Through HAProxy Load Balancer
# ============================================
# For read-write splitting via HAProxy
# PRIMARY: Write operations
DATABASE_PRIMARY_URL=postgresql://postgres:postgres@localhost:5000/ecommerce
# REPLICA: Read-only operations
REPLICA_URL=postgresql://postgres:postgres@localhost:5001/ecommerce

# ============================================
# API-specific Database URLs
# ============================================
# Used by the API server with container networking
# READ database URL (queries, read operations)
READ_DATABASE_URL=postgresql://app:app@postgres-haproxy:5000/ecommerce
# WRITE database URL (mutations, write operations)
WRITE_DATABASE_URL=postgresql://app:app@postgres-primary:5432/ecommerce

# ============================================
# Next.js Applications
# ============================================
# Public API URL accessible from the client
# Used by Next.js apps (web and admin) to make API requests
NEXT_PUBLIC_API_URL=http://localhost:4000/api
